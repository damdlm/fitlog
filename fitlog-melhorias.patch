diff --git a/.github/workflows/ci.yml b/.github/workflows/ci.yml
new file mode 100644
index 0000000..8036e05
--- /dev/null
+++ b/.github/workflows/ci.yml
@@ -0,0 +1,53 @@
+name: CI
+
+on:
+  push:
+    branches: [main]
+  pull_request:
+    branches: [main]
+
+jobs:
+  lint-and-test:
+    runs-on: ubuntu-latest
+
+    env:
+      # Necessária só para o import de config.py não falhar durante o
+      # setup de testes; os testes em si usam SQLite em memória.
+      SECRET_KEY: ci-only-secret-key-not-for-production
+      FLASK_ENV: testing
+
+    steps:
+      - name: Checkout do código
+        uses: actions/checkout@v4
+
+      - name: Configurar Python
+        uses: actions/setup-python@v5
+        with:
+          python-version: "3.12"
+          cache: "pip"
+
+      - name: Instalar dependências do sistema (libpq para psycopg2)
+        run: sudo apt-get update && sudo apt-get install -y libpq-dev
+
+      - name: Instalar dependências Python
+        run: |
+          python -m pip install --upgrade pip
+          pip install -r requirements.txt
+
+      - name: Lint (flake8)
+        run: |
+          # E9/F: erros de sintaxe e imports quebrados nunca podem passar.
+          # O resto do flake8 (estilo) só gera aviso, não quebra o build.
+          flake8 . --count --select=E9,F63,F7,F82 --show-source --statistics
+          flake8 . --count --exit-zero --max-line-length=120 --statistics
+
+      - name: Rodar testes com cobertura
+        run: |
+          pytest tests/ --cov=. --cov-report=term-missing --cov-report=xml
+
+      - name: Publicar relatório de cobertura como artefato
+        if: always()
+        uses: actions/upload-artifact@v4
+        with:
+          name: coverage-report
+          path: coverage.xml
