# ============================================================
# FITLOG — Exemplo de variáveis de ambiente
# ============================================================
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha os valores abaixo com suas configurações reais
# 3. NUNCA commite o .env — ele já está no .gitignore
# ============================================================

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/fitlog_db

# Chaves de segurança — gere valores únicos com:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
SECURITY_PASSWORD_SALT=

# Senha do usuário admin criado no primeiro boot
# Use uma senha forte com letras, números e caracteres especiais
ADMIN_PASSWORD=

# Ambiente da aplicação
# development -> DEBUG ativo, logs verbosos
# production  -> DEBUG desativado, cookies seguros
FLASK_ENV=development
FLASK_DEBUG=True
LOG_LEVEL=INFO

# E-mail (SendGrid) — usado para enviar o e-mail de recuperação de senha.
# Enviado via API HTTPS (não SMTP), pois a Railway bloqueia portas SMTP
# de saída por padrão. Crie uma conta gratuita em https://sendgrid.com
# e gere a API key em Settings > API Keys.
# O MAIL_DEFAULT_SENDER precisa ser verificado em Settings > Sender
# Authentication > Single Sender Verification (pode ser um Gmail, sem
# precisar de domínio próprio).
# Se SENDGRID_API_KEY ficar vazia, o link de reset é apenas escrito no
# log da aplicação em vez de enviado por e-mail (útil em dev local).
SENDGRID_API_KEY=
MAIL_DEFAULT_SENDER=
