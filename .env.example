# ============================================================
# FITLOG — Exemplo de variáveis de ambiente
# ============================================================
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha os valores abaixo com suas configurações reais
# 3. NUNCA commite o .env — ele já está no .gitignore
# ============================================================

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/fitlog_db

# Chaves de segurança — gere valores únicos com:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
SECURITY_PASSWORD_SALT=

# Senha do usuário admin criado no primeiro boot
# Use uma senha forte com letras, números e caracteres especiais
ADMIN_PASSWORD=

# Ambiente da aplicação
# development -> DEBUG ativo, logs verbosos
# production  -> DEBUG desativado, cookies seguros
FLASK_ENV=development
FLASK_DEBUG=True
LOG_LEVEL=INFO

# SMTP — usado para enviar o e-mail de recuperação de senha.
# Se MAIL_SERVER ficar vazio, o link de reset é apenas escrito no log
# da aplicação em vez de enviado por e-mail (útil em dev local).
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
